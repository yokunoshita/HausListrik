<Window x:Class="HausListrik.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Haus Listrik"
        Width="760"
        Height="520"
        MinWidth="680"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="#101522">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="24"
                CornerRadius="20"
                Background="#182235">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="14"
                               Foreground="#7DA4F9"
                               Text="Haus Listrik" />
                    <TextBlock Margin="0,10,0,8"
                               FontSize="34"
                               FontWeight="SemiBold"
                               Foreground="#F4F7FB"
                               Text="{Binding Headline}" />
                    <TextBlock MaxWidth="420"
                               FontSize="15"
                               Foreground="#B8C4D9"
                               TextWrapping="Wrap"
                               Text="{Binding Subheadline}" />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="18"
                        CornerRadius="18"
                        Background="#0F1726">
                    <StackPanel>
                        <TextBlock FontSize="14"
                                   Foreground="#8BA4CC"
                                   Text="Live Status" />
                        <TextBlock Margin="0,10,0,0"
                                   FontSize="38"
                                   FontWeight="Bold"
                                   Foreground="#FFFFFF"
                                   Text="{Binding BatteryPercentageLabel}" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="14"
                                   Foreground="#A8B5CC"
                                   Text="{Binding PowerSourceLabel}" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="14"
                                   Foreground="#A8B5CC"
                                   Text="{Binding BrightnessLabel}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="2"
                     Columns="3"
                     HorizontalAlignment="Stretch">
            <Border Margin="0,0,12,0"
                    Padding="18"
                    CornerRadius="18"
                    Background="#1B2740">
                <StackPanel>
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#F4F7FB"
                               Text="Voice Pack" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#AAB6CC"
                               TextWrapping="Wrap"
                               Text="Pakai Windows Speech supaya MVP langsung hidup tanpa file audio tambahan." />
                </StackPanel>
            </Border>

            <Border Margin="0,0,12,0"
                    Padding="18"
                    CornerRadius="18"
                    Background="#1B2740">
                <StackPanel>
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#F4F7FB"
                               Text="Auto Dim" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#AAB6CC"
                               TextWrapping="Wrap"
                               Text="Brightness turun bertahap mengikuti persen baterai, dengan minimum threshold supaya tetap usable." />
                </StackPanel>
            </Border>

            <Border Padding="18"
                    CornerRadius="18"
                    Background="#1B2740">
                <StackPanel>
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#F4F7FB"
                               Text="Charging Burst" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#AAB6CC"
                               TextWrapping="Wrap"
                               Text="Saat charger masuk, app langsung teriak lega dengan volume speech yang lebih agresif." />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Padding="22"
                    CornerRadius="20"
                    Background="#182235">
                <StackPanel>
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#F4F7FB"
                               Text="Controls" />

                    <CheckBox Margin="0,18,0,0"
                              Foreground="#D8E1F1"
                              Content="Chaos mode"
                              IsChecked="{Binding IsChaosModeEnabled}" />
                    <CheckBox Margin="0,12,0,0"
                              Foreground="#D8E1F1"
                              Content="Auto dim screen"
                              IsChecked="{Binding IsAutoDimEnabled}" />
                    <CheckBox Margin="0,12,0,0"
                              Foreground="#D8E1F1"
                              Content="Shout louder when charging"
                              IsChecked="{Binding IsChargingBurstEnabled}" />
                    <CheckBox Margin="0,12,0,0"
                              Foreground="#D8E1F1"
                              Content="Launch on Windows startup"
                              IsChecked="{Binding IsLaunchOnStartupEnabled}" />
                    <CheckBox Margin="0,12,0,0"
                              Foreground="#D8E1F1"
                              Content="Prefer custom WAV voice pack"
                              IsChecked="{Binding PreferAudioFiles}" />
                    <CheckBox Margin="0,12,0,0"
                              Foreground="#D8E1F1"
                              Content="Minimize to tray when closed"
                              IsChecked="{Binding IsMinimizeToTrayEnabled}" />

                    <TextBlock Margin="0,18,0,0"
                               Foreground="#AAB6CC"
                               Text="Active voice pack" />
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="110" />
                        </Grid.ColumnDefinitions>
                        <ComboBox ItemsSource="{Binding AvailableVoicePacks}"
                                  SelectedItem="{Binding SelectedVoicePack, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="2"
                                Height="30"
                                Command="{Binding RefreshVoicePacksCommand}"
                                Content="Refresh" />
                    </Grid>

                    <TextBlock Margin="0,18,0,0"
                               Foreground="#AAB6CC"
                               Text="Polling interval (seconds)" />
                    <Slider Margin="0,8,0,0"
                            Minimum="2"
                            Maximum="15"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            Value="{Binding PollingIntervalSeconds}" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#D8E1F1"
                               Text="{Binding PollingIntervalLabel}" />

                    <StackPanel Margin="0,22,0,0"
                                Orientation="Horizontal">
                        <Button Width="110"
                                Height="38"
                                Margin="0,0,12,0"
                                Command="{Binding StartCommand}"
                                Content="Start" />
                        <Button Width="110"
                                Height="38"
                                Margin="0,0,12,0"
                                Command="{Binding StopCommand}"
                                Content="Stop" />
                        <Button Width="150"
                                Height="38"
                                Margin="0,0,12,0"
                                Command="{Binding SaveSettingsCommand}"
                                Content="Save Settings" />
                        <Button Width="160"
                                Height="38"
                                Command="{Binding OpenVoicePackFolderCommand}"
                                Content="Open Voice Pack" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Padding="22"
                    CornerRadius="20"
                    Background="#182235">
                <StackPanel>
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#F4F7FB"
                               Text="Last Voice Line" />
                    <TextBlock Margin="0,16,0,0"
                               FontSize="18"
                               Foreground="#7DA4F9"
                               Text="{Binding LastSpokenLine}" />
                    <TextBlock Margin="0,18,0,0"
                               Foreground="#AAB6CC"
                               TextWrapping="Wrap"
                               Text="{Binding VoicePackDirectoryLabel}" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#AAB6CC"
                               TextWrapping="Wrap"
                               Text="Pisahkan tiap karakter ke subfolder sendiri di bawah Assets\VoicePack, lalu pilih pack-nya dari dropdown." />

                    <TextBlock Margin="0,24,0,0"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#F4F7FB"
                               Text="Diagnostics" />
                    <TextBlock Margin="0,16,0,0"
                               Foreground="#D8E1F1"
                               TextWrapping="Wrap"
                               Text="{Binding Diagnostics}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
